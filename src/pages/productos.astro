---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL;

const url = (path) => {
  const cleanBase = base.endsWith("/") ? base : `${base}/`;
  const cleanPath = path.replace(/^\/+/, "");
  return `${cleanBase}${cleanPath}`;
};

const productos = Object.values(
  import.meta.glob("../content/productos/*.md", { eager: true })
);

const categorias = [
  ...new Set(
    productos
      .map((producto: any) => producto.frontmatter.categoria)
      .filter(Boolean)
  ),
];
---

<Layout title="Productos">
  <section class="products-hero">
    <div>
      <p class="eyebrow">Catálogo</p>
      <h1>Productos para tus mascotas</h1>
      <p class="hero-text">
        Explorá productos disponibles en Norte Agroveterinaria. Consultá precio,
        disponibilidad o recomendaciones directamente por WhatsApp.
      </p>
    </div>

    <div class="products-hero-card">
      <span>🐾</span>
      <h2>Consultas rápidas</h2>
      <p>
        Tocá “Consultar por WhatsApp” en cualquier producto y te preparamos el mensaje automáticamente.
      </p>
    </div>
  </section>

  <section class="products-toolbar">
    <div class="search-box">
      <label for="product-search">Buscar producto</label>
      <input
        id="product-search"
        type="search"
        placeholder="Buscar por nombre, descripción o categoría..."
      />
    </div>

    <div class="filter-box">
      <span>Filtrar por categoría</span>

      <div class="filter-buttons">
        <button class="filter-button active" type="button" data-category="todos">
          Todos
        </button>

        {categorias.map((categoria) => (
          <button class="filter-button" type="button" data-category={categoria}>
            {categoria}
          </button>
        ))}
      </div>
    </div>
  </section>

  <div class="products-count">
    <span id="products-count">{productos.length}</span>
    <span>producto{productos.length === 1 ? "" : "s"} visible{productos.length === 1 ? "" : "s"}</span>
  </div>

  <section class="products-grid" id="products-grid">
    {productos.map((producto: any) => {
      const p = producto.frontmatter;

      const nombre = p.nombre ?? "Producto";
      const descripcion = p.descripcion ?? "";
      const categoria = p.categoria ?? "Otros";
      const estado = p.estado ?? "Consultar disponibilidad";
      const precio = p.precio ?? "";

      const mensaje = encodeURIComponent(
        `Hola! Quería consultar por el producto: ${nombre}`
      );

      const whatsapp = `https://wa.me/5493624536625?text=${mensaje}`;

      const searchText = `${nombre} ${descripcion} ${categoria} ${estado}`.toLowerCase();

      return (
        <article
          class="product-card"
          data-product-card
          data-category={categoria}
          data-search={searchText}
        >
          <div class="product-image-wrap">
            {p.imagen ? (
              <img src={url(p.imagen)} alt={nombre} />
            ) : (
              <div class="product-placeholder">
                <span>🐶</span>
                <small>Imagen del producto</small>
              </div>
            )}

            <span class="product-status">{estado}</span>
          </div>

          <div class="product-content">
            <p class="product-category">{categoria}</p>
            <h2>{nombre}</h2>
            <p class="product-description">{descripcion}</p>

            <div class="product-footer">
              <p class="product-price">
                {precio ? `$${precio}` : "Consultar precio"}
              </p>

              <a class="button product-button" href={whatsapp} target="_blank">
                Consultar
              </a>
            </div>
          </div>
        </article>
      );
    })}
  </section>

  <section class="empty-products-message" id="empty-products-message" hidden>
    <h2>No encontramos productos</h2>
    <p>
      Probá con otra búsqueda o seleccioná otra categoría.
    </p>
  </section>

  <section class="section contact-banner">
    <div>
      <p class="eyebrow">¿No encontrás lo que buscás?</p>
      <h2>Consultanos por WhatsApp</h2>
      <p>
        Podemos ayudarte con disponibilidad, precios o recomendaciones para tu mascota.
      </p>
    </div>

    <a class="button" href="https://wa.me/5493624536625" target="_blank">
      Escribir por WhatsApp
    </a>
  </section>

  <script>
    const searchInput = document.querySelector("#product-search");
    const filterButtons = document.querySelectorAll(".filter-button");
    const productCards = document.querySelectorAll("[data-product-card]");
    const count = document.querySelector("#products-count");
    const emptyMessage = document.querySelector("#empty-products-message");

    let activeCategory = "todos";

    function updateProducts() {
      const searchTerm = searchInput.value.trim().toLowerCase();
      let visibleCount = 0;

      productCards.forEach((card) => {
        const category = card.dataset.category;
        const searchText = card.dataset.search;

        const matchesCategory =
          activeCategory === "todos" || category === activeCategory;

        const matchesSearch = searchText.includes(searchTerm);

        const shouldShow = matchesCategory && matchesSearch;

        card.hidden = !shouldShow;

        if (shouldShow) {
          visibleCount += 1;
        }
      });

      count.textContent = visibleCount;
      emptyMessage.hidden = visibleCount !== 0;
    }

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        activeCategory = button.dataset.category;

        filterButtons.forEach((btn) => btn.classList.remove("active"));
        button.classList.add("active");

        updateProducts();
      });
    });

    searchInput.addEventListener("input", updateProducts);
  </script>
</Layout>