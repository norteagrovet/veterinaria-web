---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL;

const url = (path) => {
  const cleanBase = base.endsWith("/") ? base : `${base}/`;
  const cleanPath = path.replace(/^\/+/, "");
  return `${cleanBase}${cleanPath}`;
};
---

<Layout title="Inicio">
  <section class="home-visual-hero">
    <div class="hero-slider">
      <div class="hero-slide slide-one">
        <span>Foto principal del local / fachada</span>
      </div>
      <div class="hero-slide slide-two">
        <span>Foto con perros y gatos</span>
      </div>
      <div class="hero-slide slide-three">
        <span>Foto de atención en campo</span>
      </div>
    </div>

    <div class="hero-overlay"></div>

    <div class="home-visual-content">
      <div class="home-logo-placeholder">
        <span>Logo</span>
      </div>

      <p class="eyebrow">Veterinaria urbana y rural</p>

      <h1>Norte Agroveterinaria</h1>

      <p class="hero-text">
        Atención veterinaria para animales de compañía, visitas a campo y productos
        seleccionados para el cuidado diario de tus animales.
      </p>

      <div class="hero-actions">
        <a class="button" href={url("contacto")}>Contactanos</a>
        <a class="button button-secondary hero-secondary" href={url("servicios")}>
          Ver servicios
        </a>
      </div>
    </div>
  </section>

  <section class="home-quick-info">
    <article>
      <span>🐶</span>
      <strong>Animales de compañía</strong>
      <p>Atención para perros, gatos y mascotas.</p>
    </article>

    <article>
      <span>🐄</span>
      <strong>Animales de campo</strong>
      <p>Consultas rurales y visitas según disponibilidad.</p>
    </article>

    <article>
      <span>🦴</span>
      <strong>Productos</strong>
      <p>Accesorios, higiene, juguetes y más.</p>
    </article>
  </section>

  <section class="section split-section">
    <div>
      <p class="eyebrow">Quiénes somos</p>
      <h2>Cuidado cercano para animales y familias</h2>
      <p>
        En Norte Agroveterinaria combinamos atención veterinaria, asesoramiento claro
        y experiencia en el ámbito agropecuario. Trabajamos para acompañarte tanto
        en el cuidado cotidiano de tus mascotas como en consultas vinculadas al campo.
      </p>

      <a class="button" href={url("nosotros")}>Conocenos</a>
    </div>

    <div class="image-placeholder home-about-photo">
      <span>Placeholder imagen</span>
      <small>Foto del equipo, local o atención veterinaria</small>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Servicios</p>
      <h2>Atención veterinaria urbana y rural</h2>
      <p>
        Una veterinaria pensada para acompañar distintas necesidades: desde controles
        clínicos de perros y gatos hasta consultas relacionadas con animales de campo.
      </p>
    </div>

    <div class="home-services-grid">
      <article>
        <div class="icon-circle">🩺</div>
        <h3>Consulta general</h3>
        <p>Atención clínica, controles y orientación sanitaria.</p>
      </article>

      <article>
        <div class="icon-circle">💉</div>
        <h3>Vacunación y prevención</h3>
        <p>Seguimiento del cuidado preventivo de tus animales.</p>
      </article>

      <article>
        <div class="icon-circle">🌾</div>
        <h3>Visitas a campo</h3>
        <p>Consultas rurales y atención en contexto productivo.</p>
      </article>
    </div>

    <div class="center-action">
      <a class="button" href={url("servicios")}>Ver todos los servicios</a>
    </div>
  </section>

  <section class="section home-photo-strip">
    <div class="photo-placeholder strip-large">
      <span>Foto local</span>
      <small>Fachada o interior</small>
    </div>

    <div class="photo-placeholder strip-tall">
      <span>Foto campo</span>
      <small>Animales rurales</small>
    </div>

    <div class="photo-placeholder strip-small">
      <span>Foto productos</span>
    </div>

    <div class="photo-placeholder strip-small">
      <span>Foto mascotas</span>
    </div>
  </section>

  <section class="section split-section reverse">
    <div>
      <p class="eyebrow">Productos</p>
      <h2>Productos para el cuidado diario</h2>
      <p>
        En nuestro catálogo podés encontrar productos para mascotas y animales:
        accesorios, juguetes, higiene y artículos seleccionados. Cada producto se
        puede consultar directamente por WhatsApp.
      </p>

      <a class="button" href={url("productos")}>Ver productos</a>
    </div>

    <div class="catalog-preview">
      <div>Alimentos</div>
      <div>Accesorios</div>
      <div>Juguetes</div>
      <div>Higiene</div>
    </div>
  </section>

  <section class="section home-location-card">
    <div>
      <p class="eyebrow">Dónde estamos</p>
      <h2>En Resistencia, Chaco</h2>
      <p>
        Estamos en Benjamín Zorrilla 4235. Podés escribirnos por WhatsApp para
        consultar horarios, productos disponibles o coordinar una atención.
      </p>

      <div class="hero-actions">
        <a class="button" href={url("contacto")}>Ver contacto</a>
        <a
          class="button button-secondary"
          href="https://www.google.com/maps/search/?api=1&query=Benjam%C3%ADn%20Zorrilla%204235%2C%20Resistencia%2C%20Chaco"
          target="_blank"
        >
          Cómo llegar
        </a>
      </div>
    </div>

    <div class="map-placeholder home-map-placeholder">
      <span>Mapa / imagen exterior</span>
      <small>Acá podemos poner mapa o foto del frente del local</small>
    </div>
  </section>

  <section class="section contact-banner">
    <div>
      <p class="eyebrow">Norte Agroveterinaria</p>
      <h2>¿Querés hacer una consulta?</h2>
      <p>
        Escribinos por WhatsApp y contanos qué necesitás. Te orientamos según el caso.
      </p>
    </div>

    <a class="button" href="https://wa.me/5493624536625" target="_blank">
      Escribir por WhatsApp
    </a>
  </section>
</Layout>